# Production environment template for the Shoptimised AI Visibility app.
# Copy values into your Laravel Cloud (or other host) environment settings.
# DB_*, CACHE/QUEUE connection details and OBJECT_STORAGE_* are typically
# injected by the platform when you attach the resource — leave those blank here.

APP_NAME="Shoptimised"
APP_ENV=production
APP_KEY=                      # php artisan key:generate --show  (set once, keep stable)
APP_DEBUG=false
APP_URL=https://app.shoptimised.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database — PostgreSQL (Laravel Cloud injects DB_* when you attach Postgres).
DB_CONNECTION=pgsql
# DB_HOST=        # injected
# DB_PORT=5432    # injected
# DB_DATABASE=    # injected
# DB_USERNAME=    # injected
# DB_PASSWORD=    # injected

# Cache / sessions / locks — Valkey (attach the resource; connection injected).
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
REDIS_CLIENT=phpredis
# REDIS_HOST / REDIS_PORT / REDIS_PASSWORD injected by the Valkey resource.

# Queue — use the platform's managed queue connection.
QUEUE_CONNECTION=redis

# Object storage for raw responses / screenshots (S3-compatible).
FILESYSTEM_DISK=s3
# AWS_* / OBJECT_STORAGE_* injected by the storage resource.

# --- AI Item Group Visibility Tracker ---
# Reporting pages render inside the host chrome layout.
AI_VISIBILITY_LAYOUT=components.layouts.aiv
AI_VISIBILITY_DEFAULT_COUNTRY=GB
AI_VISIBILITY_DEFAULT_LANGUAGE=en
AI_VISIBILITY_MAX_ITEM_GROUPS_PER_BATCH=25
AI_VISIBILITY_MAX_PROMPTS_PER_BATCH=250
AI_VISIBILITY_MAX_RUNS_PER_PROMPT=3
AI_VISIBILITY_MONTHLY_BATCH_ENABLED=false   # Phase 6 (recurring monitoring)

# FAQ discovery: when an item group has no Q&A in the feed, discover the FAQs
# buyers most commonly ask (using the GTIN + item group title) and test them.
# Leave platform blank to use the first enabled search provider.
AI_VISIBILITY_FAQ_DISCOVERY=true
AI_VISIBILITY_FAQ_DISCOVERY_PLATFORM=
AI_VISIBILITY_FAQ_DISCOVERY_MAX=6

# Per-provider rate limits (requests/min) — raise on paid tiers.
AI_VISIBILITY_GEMINI_RPM=10
AI_VISIBILITY_PERPLEXITY_RPM=20
AI_VISIBILITY_OPENAI_RPM=10

# Provider API keys — set the ones you use (each enables that platform).
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
# BING_SEARCH_API_KEY=

# Error monitoring (optional).
# SENTRY_LARAVEL_DSN=
